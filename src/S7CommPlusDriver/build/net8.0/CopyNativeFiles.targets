<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup>
    <S7CommPlusNativeRuntime Include="$(MSBuildThisFileDirectory)../../runtimes/osx-arm64/native/*.dylib" Condition="Exists('$(MSBuildThisFileDirectory)../../runtimes/osx-arm64/native')">
      <RuntimeIdentifier>osx-arm64</RuntimeIdentifier>
    </S7CommPlusNativeRuntime>
    <S7CommPlusNativeRuntime Include="$(MSBuildThisFileDirectory)../../runtimes/win-arm64/native/*.dll" Condition="Exists('$(MSBuildThisFileDirectory)../../runtimes/win-arm64/native')">
      <RuntimeIdentifier>win-arm64</RuntimeIdentifier>
    </S7CommPlusNativeRuntime>
    <S7CommPlusNativeRuntime Include="$(MSBuildThisFileDirectory)../../runtimes/win-x64/native/*.dll" Condition="Exists('$(MSBuildThisFileDirectory)../../runtimes/win-x64/native')">
      <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    </S7CommPlusNativeRuntime>
    <S7CommPlusNativeRuntime Include="$(MSBuildThisFileDirectory)../../runtimes/win-x86/native/*.dll" Condition="Exists('$(MSBuildThisFileDirectory)../../runtimes/win-x86/native')">
      <RuntimeIdentifier>win-x86</RuntimeIdentifier>
    </S7CommPlusNativeRuntime>
  </ItemGroup>

  <Target Name="CopyNativeFiles" AfterTargets="Build" Condition="'@(S7CommPlusNativeRuntime)' != ''">
    <Copy
      SourceFiles="@(S7CommPlusNativeRuntime)"
      DestinationFiles="@(S7CommPlusNativeRuntime->'$(OutDir)runtimes/%(RuntimeIdentifier)/native/%(Filename)%(Extension)')"
      SkipUnchangedFiles="true" />
  </Target>
</Project>
